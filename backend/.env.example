# General / Server Configuration
PORT=3000
NODE_ENV=development
JWT_SECRET=your_secure_32_digit_secret_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
APP_BASE_URL=http://localhost:3000
DEFAULT_ITEM_PRICE_PAISE=5000

# Database Configuration (Real MongoDB Atlas Development Shard)
MONGO_URI=mongodb://localhost:27017/Smart_vending_machine_test

# Cryptography / Payment Secrets Encryption
# AES-256-GCM requires a 32-byte (64-character) hex encryption key
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Monitoring & Error Tracking
# Leave empty to disable Sentry in local/dev development
SENTRY_DSN=

# PhonePe Integration (General)
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/hermes

# PhonePe Integration (Development/UAT)
DEV_PHONEPE_MERCHANT_ID=
DEV_PHONEPE_SALT_KEY=
DEV_PHONEPE_SALT_INDEX=

# PhonePe Integration (Production)
PROD_PHONEPE_MERCHANT_ID=
PROD_PHONEPE_SALT_KEY=
PROD_PHONEPE_SALT_INDEX=

# MQTT Broker Configuration
MQTT_BROKER_URL=mqtt://test.mosquitto.org

# Email Alerts Configuration (Resend API)
RESEND_API_KEY=
ADMIN_EMAIL=

# Default Platform Admins
ADMIN_DEFAULT_EMAIL=
ADMIN_DEFAULT_PASSWORD=
ADMIN_DEFAULT_PIN=
